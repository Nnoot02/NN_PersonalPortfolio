{
  "name": "personal-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3000",
    "build": "next build && pnpm test:contract",
    "start": "next start --hostname 127.0.0.1 --port 3000",
    "check": "tsc --noEmit",
    "check:repo": "node scripts/repo-hygiene.mjs",
    "test:repo": "node --test scripts/repo-hygiene.test.mjs",
    "test:contract": "node scripts/portfolio-contract.mjs",
    "audit:deps": "pnpm audit --prod",
    "verify": "pnpm check && pnpm test:repo && pnpm check:repo && pnpm build && pnpm audit:deps"
  },
  "dependencies": {
    "@fontsource/barlow-condensed": "5.2.8",
    "@fontsource/inter": "5.2.8",
    "@phosphor-icons/react": "2.1.10",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "typescript": "6.0.3"
  }
}
